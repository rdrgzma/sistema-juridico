{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "sistema-juridico": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ],
            "env": {
                "APP_ENV": "local",
                "PHP_BINARY": "php"
            }
        }
        //other mcp servers
    }
}
// setup mcp server in  ~/.gemini\antigravity\mcp_config.json